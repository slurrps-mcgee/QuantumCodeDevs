---
import GlassCard from '../components/GlassCard.astro';
import SectionHeader from '../components/SectionHeader.astro';
import Layout from '../layouts/Layout.astro';

const serviceCards = [
	{
		title: 'Website Development',
		description: 'Conversion-focused websites, landing pages, and content platforms designed to scale with your brand.'
	},
	{
		title: 'Application Engineering',
		description: 'Robust web, mobile, and desktop software with performance, security, and usability built in from day one.'
	},
	{
		title: 'Ongoing Product Support',
		description: 'Iterative improvements, analytics-led optimization, and long-term technical guidance after launch.'
	}
];

const processSteps = [
	{
		step: '01 Discovery',
		title: 'Define Goals',
		description: 'We map requirements, user needs, and key success metrics before any implementation begins.'
	},
	{
		step: '02 Blueprint',
		title: 'Plan Scope',
		description: 'You receive a delivery plan with milestones, architecture direction, and clear estimate ranges.'
	},
	{
		step: '03 Build',
		title: 'Ship Iteratively',
		description: 'We release in small increments with weekly demos, keeping momentum and reducing project risk.'
	},
	{
		step: '04 Scale',
		title: 'Optimize Growth',
		description: 'After launch, we monitor usage, improve performance, and evolve your product roadmap.'
	}
];

const technologyColumns = [
	{
		title: 'Frontend',
		description: 'Astro, Angular 20, TypeScript, Angular Material, Ionic UI, SCSS, Tailwind CSS, NgRx, Angular Signals, RxJS.'
	},
	{
		title: 'Backend',
		description: 'Node.js LTS with NestJS (primary), REST APIs, optional GraphQL, JWT/OAuth2 auth flows, RBAC, Swagger.'
	},
	{
		title: 'Data & Real-Time',
		description: 'MySQL 8 with Sequelize, migrations and transactions, plus Socket.IO / NestJS gateways for live features.'
	},
	{
		title: 'DevOps',
		description: 'GitHub Actions CI/CD, Docker + Compose, Nginx reverse proxy, and deployment on VPS or cloud infrastructure.'
	}
];
---

<Layout
	title="Quantum Code Devs | Modern IT Solutions"
	description="Quantum Code Devs builds premium websites and software applications for web, mobile, and desktop."
	activePage="home"
>
	<section class="grid gap-10 lg:grid-cols-[1.25fr_0.75fr] lg:items-center">
		<div>
			<SectionHeader
				eyebrow="Practical Digital Delivery"
				title="We build websites and bespoke software that stay within scope and deliver real business value."
				description="Quantum Code Devs is a solo LLC focused on websites and custom software applications. I keep the offering intentionally narrow so I can deliver well, while also bringing strong C# and .NET experience when a project needs it."
				eyebrowClass="inline-flex rounded-full border border-cyan-200/30 bg-cyan-200/10 px-4 py-1 text-xs font-medium uppercase tracking-[0.22em] text-cyan-100"
				titleClass="text-4xl font-semibold leading-tight text-white md:text-6xl"
				descriptionClass="max-w-2xl text-lg text-slate-300"
			/>
			<div class="flex flex-wrap gap-3">
				<a href="/services" class="btn-primary">Explore Services</a>
				<a href="/contact" class="btn-secondary">Book a Discovery Call</a>
			</div>
		</div>

		<div class="glass-card space-y-5">
			<p class="text-xs uppercase tracking-[0.2em] text-cyan-100">Delivery Snapshot</p>
			<ul class="space-y-3 text-sm text-slate-200">
				<li class="flex items-start gap-3"><span class="mt-2 h-2 w-2 rounded-full bg-cyan-300"></span>Full-cycle web engineering with Angular, TypeScript, and NestJS APIs.</li>
				<li class="flex items-start gap-3"><span class="mt-2 h-2 w-2 rounded-full bg-violet-300"></span>Cross-platform app development for mobile and desktop experiences.</li>
				<li class="flex items-start gap-3"><span class="mt-2 h-2 w-2 rounded-full bg-cyan-300"></span>Transparent process: roadmap, weekly demos, launch support.</li>
				<li class="flex items-start gap-3"><span class="mt-2 h-2 w-2 rounded-full bg-violet-300"></span>C# and .NET development when a solution fits that platform better.</li>
			</ul>
			<div class="rounded-xl border border-white/10 bg-slate-900/70 p-4 text-sm text-slate-300">
				<p class="font-semibold text-white">Need a fast estimate?</p>
				<p>Most MVP projects begin in the $15k-$50k range, depending on scope and integrations.</p>
			</div>
		</div>
	</section>

	<section class="mt-14 grid gap-4 md:grid-cols-3">
		{
			serviceCards.map((card) => (
				<GlassCard title={card.title} titleClass="text-2xl font-semibold text-white">
					<p>{card.description}</p>
				</GlassCard>
			))
		}
	</section>

	<section class="mt-14">
		<SectionHeader
			titleTag="h2"
			eyebrow="How We Work"
			title="A practical process designed for shipping, not stalling."
			class="mb-6"
			titleClass="mt-2 text-3xl font-semibold text-white md:text-4xl"
		/>

		<div class="grid gap-4 md:grid-cols-4">
			{
				processSteps.map((step) => (
					<GlassCard title={step.title} titleTag="h3" titleClass="mt-2 text-xl font-semibold text-white" bodyClass="mt-2 text-sm text-slate-300">
						<p class="text-xs font-semibold uppercase tracking-[0.18em] text-violet-300">{step.step}</p>
						<p>{step.description}</p>
					</GlassCard>
				))
			}
		</div>
	</section>

	<!-- <section class="mt-14">
		<div class="mb-6 flex flex-wrap items-end justify-between gap-4">
			<div>
				<p class="text-xs uppercase tracking-[0.2em] text-cyan-200">Example Work</p>
				<h2 class="mt-2 text-3xl font-semibold text-white md:text-4xl">Sample projects and outcomes (placeholders)</h2>
