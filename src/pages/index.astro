	<section class="mt-14">
		<SectionHeader
			titleTag="h2"
			eyebrow="Technology Stack"
			title="Primary stack for production-grade web, mobile, and desktop products."
			class="mb-6"
			titleClass="mt-2 text-3xl font-semibold text-white md:text-4xl"
		/>

		<div class="grid gap-4 md:grid-cols-2 lg:grid-cols-4">
			{
				technologyColumns.map((column) => (
					<GlassCard title={column.title} titleTag="h3" titleClass="text-lg font-semibold text-white" bodyClass="mt-2 text-sm text-slate-300">
						<p>{column.description}</p>
					</GlassCard>
				))
			}
		</div>

		<div class="mt-4 rounded-xl border border-cyan-300/20 bg-cyan-300/5 p-4 text-sm text-slate-200">
			<p><strong class="text-white">Core stack includes:</strong> Astro + Tailwind delivery for marketing sites, content platforms, and custom web applications.</p>
		</div>
	</section>

	<section class="mt-14 grid gap-4 lg:grid-cols-[0.95fr_1.05fr]">
		<article class="glass-card">
			<p class="text-xs uppercase tracking-[0.2em] text-cyan-200">Founder Profile</p>
			<h2 class="mt-2 text-3xl font-semibold text-white">Built by one developer, with a focused service model.</h2>
			<p class="mt-3 text-slate-300">This business is intentionally lean: one experienced developer, clear communication, and a realistic workload so projects stay manageable and high quality.</p>
			<div class="mt-4 flex flex-wrap gap-3">
				<a href="/developers" class="btn-primary">View Developer Profile</a>
			</div>
		</article>

		<article class="glass-card">
			<h2 class="text-2xl font-semibold text-white">Quick Links</h2>
			<div class="mt-4 grid gap-3 sm:grid-cols-2">
				<a href="https://kenny.quantumcode.dev" target="_blank" rel="noreferrer" class="rounded-xl border border-white/10 bg-slate-900/55 p-4 text-slate-200 transition hover:border-cyan-300 hover:text-white">
					<p class="text-xs uppercase tracking-[0.16em] text-cyan-300">Portfolio</p>
					<p class="mt-2 font-semibold">Your portfolio site</p>
				</a>
				<a href="https://github.com/slurrps-mcgee" target="_blank" rel="noreferrer" class="rounded-xl border border-white/10 bg-slate-900/55 p-4 text-slate-200 transition hover:border-violet-300 hover:text-white">
					<p class="text-xs uppercase tracking-[0.16em] text-violet-300">GitHub</p>
					<p class="mt-2 font-semibold">Your GitHub profile</p>
				</a>
			</div>
		</article>
	</section>
</Layout>
