---
import Layout from '../../layouts/Layout.astro';
import { getCollection, render } from 'astro:content';

export async function getStaticPaths() {
  const posts = await getCollection('blog');

  return posts.map((post) => ({
    params: { slug: post.id },
    props: { post }
  }));
}

const { post } = Astro.props;
const { Content } = await render(post);

const allPosts = (await getCollection('blog')).sort(
  (a, b) => b.data.publishDate.getTime() - a.data.publishDate.getTime()
);

const relatedPosts = allPosts.filter((p) => p.id !== post.id).slice(0, 3);

const plainText = (post.body ?? '')
  .replace(/```[\s\S]*?```/g, ' ')
  .replace(/`[^`]*`/g, ' ')
  .replace(/!\[[^\]]*\]\([^)]*\)/g, ' ')
  .replace(/\[[^\]]*\]\([^)]*\)/g, ' ')
  .replace(/[#>*_\-]/g, ' ')
  .replace(/\s+/g, ' ')
  .trim();

const wordCount = plainText ? plainText.split(' ').length : 0;
const readTime = Math.max(1, Math.ceil(wordCount / 200));
---

<Layout
  title={`${post.data.title} | Bits And Bytes IT Solutions Blog`}
  description={post.data.description}
  activePage="blog"
>
  <section class="bg-slate-950 px-4 py-8 sm:px-6 lg:px-8 lg:py-14">
    <div class="mx-auto max-w-3xl">
      <a href="/blog" class="mb-8 inline-block text-violet-400 transition hover:text-cyan-400">← Back to Blog</a>

      <article class="card border-2 border-slate-700">
        <h1 class="mb-6 text-4xl font-bold text-white md:text-5xl">{post.data.title}</h1>
        <div class="mb-8 flex flex-wrap gap-4 border-b border-slate-700 pb-6 text-slate-400">
          <span>By <strong class="text-white">{post.data.author}</strong></span>
          <span>•</span>
          <span>{post.data.publishDate.toLocaleDateString('en-US', {
            year: 'numeric',
            month: 'long',
            day: 'numeric'
          })}</span>
          <span>•</span>
          <span>{readTime} min read</span>
        </div>

        <div class="prose prose-invert max-w-none prose-headings:text-violet-400 prose-h3:text-white prose-strong:text-white prose-p:text-slate-300 prose-li:text-slate-300 prose-a:text-cyan-400">
          <Content />
        </div>
      </article>

      {
        relatedPosts.length > 0 && (
          <div class="mt-12">
            <h2 class="mb-8 text-3xl font-bold text-white">Related Articles</h2>
            <div class="grid gap-6">
              {relatedPosts.map((related) => (
                <a href={`/blog/${related.id}`} class="card group hover:border-violet-500">
                  <h3 class="mb-2 text-xl font-bold text-white transition-colors group-hover:text-violet-400">
                    {related.data.title}
                  </h3>
                  <p class="mb-3 line-clamp-2 text-slate-400">{related.data.description}</p>
                  <div class="flex items-center justify-between text-sm text-slate-500">
                    <span>By {related.data.author}</span>
                    <span class="font-semibold text-violet-400 transition-transform group-hover:translate-x-1">
                      Read →
                    </span>
                  </div>
                </a>
              ))}
            </div>
          </div>
        )
      }
    </div>
  </section>
</Layout>
