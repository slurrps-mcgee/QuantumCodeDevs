---
import Layout from '../../layouts/Layout.astro';
import { getCollection } from 'astro:content';

const posts = (await getCollection('blog')).sort(
  (a, b) => b.data.publishDate.getTime() - a.data.publishDate.getTime()
);
---

<Layout
  title="Blog | Bits And Bytes IT Solutions"
  description="Read strategy, architecture, and delivery insights from Bits And Bytes IT Solutions."
  activePage="blog"
>
  <section class="py-8 sm:py-12">
    <div class="mx-auto max-w-7xl">
      <h1 class="section-title text-center">Engineering Blog</h1>
      <p class="section-subtitle mx-auto mt-3 max-w-2xl text-center">
        Latest articles, implementation guides, and product delivery notes.
      </p>

      {
        posts.length > 0 ? (
          <div class="mt-12 grid gap-8 md:grid-cols-2 lg:grid-cols-3">
            {posts.map((post, index) => (
              <a href={`/blog/${post.id}`} class="card fade-rise group flex h-full flex-col" style={`--delay: ${index * 90 + 70}ms;`}>
                <h2 class="mb-3 line-clamp-2 text-2xl font-bold text-white transition-colors group-hover:text-violet-400">
                  {post.data.title}
                </h2>

                <p class="mb-4 line-clamp-3 flex-grow text-slate-400">
                  {post.data.description}
                </p>

                <div class="border-t border-slate-700 pt-4">
                  <p class="mb-2 text-sm text-slate-500">By {post.data.author}</p>
                  <p class="text-sm font-semibold text-violet-400">
                    {post.data.publishDate.toLocaleDateString('en-US', {
                      year: 'numeric',
                      month: 'long',
                      day: 'numeric'
                    })}
                  </p>
                </div>

                <div class="mt-4 font-semibold text-violet-400 transition-transform group-hover:translate-x-2">
                  Read More →
                </div>
              </a>
            ))}
          </div>
        ) : (
          <div class="py-12 text-center">
            <p class="text-slate-400">No blog posts yet. Check back soon.</p>
          </div>
        )
      }
    </div>
  </section>
</Layout>
