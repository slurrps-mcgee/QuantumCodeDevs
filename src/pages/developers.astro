---
import GlassCard from '../components/GlassCard.astro';
import InsetCard from '../components/InsetCard.astro';
import SectionHeader from '../components/SectionHeader.astro';
import Layout from '../layouts/Layout.astro';

const portfolioUrl = 'https://kenny.quantumcode.dev';
const githubUrl = 'https://github.com/QuantumCodeDevs';

const strengths = [
  {
    title: 'Frontend',
    description: 'Astro, Angular, Ionic, Tailwind CSS, SCSS, RxJS, NgRx, Angular Signals.'
  },
  {
    title: 'Backend',
    description: 'NestJS, Node.js, MySQL, API design, auth flows, and integrations.'
  },
  {
    title: 'Desktop',
    description: 'Electron apps with offline support and native integration points.'
  },
  {
    title: 'Microsoft Stack',
    description: 'C# / .NET when a project benefits from a Microsoft platform fit.'
  }
];

const links = [
  {
    label: 'Portfolio',
    textClass: 'text-cyan-300',
    hoverClass: 'hover:border-cyan-300',
    href: portfolioUrl,
    description: 'Visit the main portfolio / personal site for Quantum Code Devs.'
  },
  {
    label: 'GitHub',
    textClass: 'text-violet-300',
    hoverClass: 'hover:border-violet-300',
    href: githubUrl,
    description: 'Visit the GitHub profile for Quantum Code Devs.'
  }
];
---

<Layout
  title="Developers | Quantum Code Devs"
  description="Developer profile page for Quantum Code Devs."
  activePage="developers"
>
  <SectionHeader
    eyebrow="Developer Profile"
    title="The developer behind Quantum Code Devs."
    description="For now, the business is just one developer: a solo founder focused on delivering websites, bespoke software applications, and Astro-powered platforms as a core offering."
  />

  <section class="mt-10 grid gap-4 lg:grid-cols-[0.95fr_1.05fr]">
    <GlassCard>
      <div class="h-40 rounded-xl border border-white/10 bg-gradient-to-br from-cyan-500/20 to-violet-500/20"></div>
      <h2 class="mt-4 text-2xl font-semibold text-white">Kenneth Lamb: Solo Founder</h2>
      <p class="mt-3 text-slate-300">
        Direct communication, fast decisions, and a realistic delivery model keep projects moving without the overhead of a larger agency.
      </p>
      <div class="mt-5 flex flex-wrap gap-3">
        <a href={portfolioUrl} target="_blank" rel="noreferrer" class="btn-primary">Quantum Code Devs Portfolio</a>
        <a href={githubUrl} target="_blank" rel="noreferrer" class="btn-secondary">GitHub</a>
      </div>
    </GlassCard>

    <GlassCard class="space-y-4" title="Core Strengths">
      <div class="grid gap-3 md:grid-cols-2">
        {
          strengths.map((strength) => (
            <InsetCard>
              <h3 class="font-semibold text-white">{strength.title}</h3>
              <p class="mt-2 text-sm text-slate-300">{strength.description}</p>
            </InsetCard>
          ))
        }
      </div>
    </GlassCard>
  </section>

  <GlassCard as="section" class="mt-10" title="What I Typically Link To">
    <div class="mt-4 grid gap-3 md:grid-cols-2">
      {
        links.map((link) => (
          <a href={link.href} target="_blank" rel="noreferrer" class:list={['rounded-xl border border-white/10 bg-slate-900/55 p-4 transition', link.hoverClass]}>
            <p class:list={['text-xs uppercase tracking-[0.16em]', link.textClass]}>{link.label}</p>
            <p class="mt-2 text-slate-200">{link.description}</p>
          </a>
        ))
      }
    </div>
  </GlassCard>
</Layout>
