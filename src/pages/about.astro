---
import GlassCard from '../components/GlassCard.astro';
import InsetCard from '../components/InsetCard.astro';
import SectionHeader from '../components/SectionHeader.astro';
import Layout from '../layouts/Layout.astro';

const servicePillars = [
  {
    title: 'Product Discovery',
    description: 'We map business goals to technical requirements, reducing expensive pivots later.'
  },
  {
    title: 'Design + Build',
    description: 'UX, interface systems, and robust implementation developed as one integrated process.'
  },
  {
    title: 'Launch + Grow',
    description: 'Post-launch support, performance tuning, and roadmap planning for continuous growth.'
  }
];

const deliveryModel = [
  {
    title: 'Weekly Momentum',
    description: 'Structured check-ins, async updates, and review demos ensure progress is visible and decisions are quick.'
  },
  {
    title: 'Roadmap-Driven Execution',
    description: 'We break work into practical milestones tied to business outcomes, not just feature lists.'
  },
  {
    title: 'Modern Engineering Stack',
    description: 'Angular, Ionic, Electron, NestJS, MySQL, and C# / .NET power scalable systems with a clean TypeScript-first foundation.'
  },
  {
    title: 'Support Beyond Launch',
    description: 'We continue with optimization, enhancements, and technical advisory as your product evolves.'
  }
];

const industries = [
  'Service businesses modernizing operations and sales workflows',
  'Startups validating MVP products and scaling into v2 platforms',
  'Internal teams replacing spreadsheets and legacy tools with purpose-built software',
  'Organizations needing secure web portals, dashboards, and admin systems'
];

const engagements = [
  {
    title: 'Fixed-Scope Build',
    description: 'Best for clearly defined deliverables and timelines.'
  },
  {
    title: 'Monthly Retainer',
    description: 'Ongoing development and iteration for growing products.'
  },
  {
    title: 'Technical Partner Support',
    description: 'Architecture planning, codebase audits, and team enablement.'
  }
];
---

<Layout
  title="About | Quantum Code Devs"
  description="Learn about Quantum Code Devs and how we deliver web and software products."
  activePage="about"
>
  <section class="grid gap-8 lg:grid-cols-[1.2fr_0.8fr] lg:items-start">
    <div class="space-y-5">
      <p class="inline-flex rounded-full border border-violet-200/30 bg-violet-200/10 px-4 py-1 text-xs font-medium uppercase tracking-[0.22em] text-violet-100">
        About Quantum Code Devs
      </p>
      <h1 class="text-4xl font-semibold text-white md:text-5xl">
        We build practical digital products as a solo LLC, with a scope that stays realistic and focused.
      </h1>
      <p class="text-lg text-slate-300">
        Quantum Code Devs partners with founders, business owners, and internal teams to design, build, and scale web, mobile, and desktop software. The business is currently just me, which keeps communication direct and the delivery model honest.
      </p>
      <p class="text-slate-300">
        My core strengths are Angular, Ionic, Electron, NestJS, MySQL, and C# / .NET when the project calls for it, so I can match the technology to the problem instead of forcing one stack everywhere.
      </p>
    </div>

    <aside class="glass-card">
      <h2 class="text-2xl font-semibold text-white">What We Stand For</h2>
      <ul class="mt-4 space-y-3 text-sm text-slate-200">
        <li><strong class="text-white">Clarity:</strong> We define scope and milestones before writing production code.</li>
        <li><strong class="text-white">Craft:</strong> We focus on architecture, maintainability, and user experience quality.</li>
        <li><strong class="text-white">Velocity:</strong> We ship in small, testable increments with weekly demos.</li>
        <li><strong class="text-white">Ownership:</strong> We communicate proactively and treat your product goals as shared goals.</li>
        <li><strong class="text-white">Focus:</strong> We only take on work we can deliver well, rather than overextending the business.</li>
      </ul>
    </aside>
  </section>

  <section class="mt-12 grid gap-4 md:grid-cols-3">
    {
      servicePillars.map((pillar) => (
        <GlassCard title={pillar.title} titleClass="text-xl font-semibold text-white">
          <p>{pillar.description}</p>
        </GlassCard>
      ))
    }
  </section>

  <GlassCard as="section" class="mt-12" title="Our Delivery Model">
    <div class="mt-4 grid gap-4 md:grid-cols-2">
      {
        deliveryModel.map((item) => (
          <InsetCard>
            <h3 class="text-lg font-semibold text-white">{item.title}</h3>
            <p class="mt-2 text-sm text-slate-300">{item.description}</p>
          </InsetCard>
        ))
      }
    </div>
  </GlassCard>

  <section class="mt-12 grid gap-4 lg:grid-cols-2">
    <GlassCard title="Industries We Commonly Support">
      <ul class="mt-4 space-y-3 text-slate-300">
        {industries.map((industry) => <li>{industry}</li>)}
      </ul>
    </GlassCard>

    <GlassCard title="Engagement Formats">
      <ul class="mt-4 space-y-3 text-slate-300">
        {
          engagements.map((item) => (
            <li><strong class="text-white">{item.title}:</strong> {item.description}</li>
          ))
        }
      </ul>
    </GlassCard>
  </section>

  <section class="mt-12 rounded-2xl border border-cyan-300/20 bg-cyan-300/5 p-6 md:p-8">
    <SectionHeader
      titleTag="h2"
      title="Let’s build the right thing, not just the next thing."
      description="If you are planning a website refresh, a business application, or a full product build, we can help you scope it clearly and execute it with confidence."
      class="space-y-3"
      titleClass="text-3xl font-semibold text-white"
      descriptionClass="max-w-3xl text-slate-300"
    />
    <div class="mt-5 flex flex-wrap gap-3">
      <a href="/contact" class="btn-primary">Start a Project Conversation</a>
      <a href="/services" class="btn-secondary">Review Services & Pricing</a>
    </div>
  </section>
</Layout>
