---
import GlassCard from '../components/GlassCard.astro';
import InsetCard from '../components/InsetCard.astro';
import SectionHeader from '../components/SectionHeader.astro';
import Layout from '../layouts/Layout.astro';

const coreServices = [
  {
    title: 'Web Application Delivery',
    description: 'Astro and Angular-based platforms, admin systems, portals, and dashboards with strong UX and scalable architecture.'
  },
  {
    title: 'Mobile Application Delivery',
    description: 'Ionic + Angular mobile apps with Capacitor integrations for native features on Android and iOS.'
  },
  {
    title: 'Desktop Application Delivery',
    description: 'Electron + Angular desktop tools with offline support, local workflows, and operational reliability.'
  },
  {
    title: 'Backend & API Systems',
    description: 'NestJS/Node.js APIs, authentication, authorization, integrations, and MySQL-backed data layers. C# / .NET options are available when a Microsoft stack is the right fit.'
  }
];

const includedItems = [
  '<strong class="text-white">Planning:</strong> Scope definition, milestones, timeline mapping, and risk alignment.',
  '<strong class="text-white">Delivery:</strong> Iterative builds with weekly progress demos and actionable feedback loops.',
  '<strong class="text-white">Quality:</strong> Production standards for maintainability, performance, and operational stability.',
  '<strong class="text-white">Handover:</strong> Documentation, deployment guidance, and post-launch support options.'
];

const pricingFactors = [
  '<strong class="text-white">Complexity:</strong> Advanced features, integrations, and custom workflows increase effort.',
  '<strong class="text-white">Timeline:</strong> Tight deadlines usually require added team capacity and premium rates.',
  '<strong class="text-white">Location:</strong> Typical rates differ across regions and talent markets.'
];

const techStack = [
  '<strong class="text-white">Web Platforms:</strong> Astro, Tailwind CSS, TypeScript, component-driven architecture, and content modeling for scalable websites and portals.',
  '<strong class="text-white">Web Apps:</strong> Angular 20, TypeScript, Angular Material, SCSS, Tailwind CSS, NgRx, Angular Signals.',
  '<strong class="text-white">Mobile Apps:</strong> Ionic + Angular with Capacitor for Android/iOS and native integrations.',
  '<strong class="text-white">Desktop Apps:</strong> Electron + Angular with local storage, file-system access, and offline support.',
  '<strong class="text-white">Backend:</strong> Node.js LTS + NestJS, JWT/OAuth2 auth, RBAC, validation, and Swagger docs.',
  '<strong class="text-white">Database:</strong> MySQL 8 with Sequelize (or TypeORM/Prisma), migrations, pooling, and transactions.',
  '<strong class="text-white">DevOps:</strong> Docker, GitHub Actions, Nginx, and cloud/VPS deployment pipelines.'
];
---

<Layout
	  title="Services & Pricing | Quantum Code Devs"
  description="Explore services and pricing for web, mobile, and desktop software development."
  activePage="services"
>
  <SectionHeader
    eyebrow="Services & Pricing"
    title="Product-focused engineering services for web, mobile, desktop, and backend systems."
    description="We help teams scope clearly, build confidently, and launch maintainable digital products. Every engagement is shaped around business outcomes, technical quality, and delivery speed."
  />

  <section class="mt-10 grid gap-4 md:grid-cols-2 lg:grid-cols-4">
    {
      coreServices.map((service) => (
        <GlassCard title={service.title} titleClass="text-xl font-semibold text-white" bodyClass="mt-2 text-sm text-slate-300">
          <p>{service.description}</p>
        </GlassCard>
      ))
    }
  </section>

  <section class="mt-10 grid gap-4 md:grid-cols-3">
    <article class="glass-card">
      <h2 class="text-2xl font-semibold text-white">Base Hourly Rate</h2>
      <ul class="mt-3 space-y-2 text-slate-300">
        <li>Standard delivery rate: <strong class="text-white">$50/hr</strong></li>
      </ul>
      <p class="mt-3 text-sm text-slate-400">Fixed-scope and milestone-based pricing is available for clearly defined projects.</p>
    </article>

    <article class="glass-card md:col-span-2">
      <h2 class="text-2xl font-semibold text-white">Project-Based Pricing</h2>
      <div class="mt-4 grid gap-4 md:grid-cols-3">
        <div class="rounded-xl border border-white/10 bg-slate-900/60 p-4">
          <h3 class="text-lg font-semibold text-cyan-100">Web Applications</h3>
          <ul class="mt-2 space-y-2 text-sm text-slate-300">
            <li>Basic website: <strong class="text-white">$1,000 - $5,000</strong></li>
            <li>Small web app: <strong class="text-white">$5,000 - $15,000</strong></li>
            <li>Medium complexity: <strong class="text-white">$15,000 - $50,000</strong></li>
            <li>Complex platform: <strong class="text-white">$50,000 - $150,000+</strong></li>
          </ul>
        </div>

        <div class="rounded-xl border border-white/10 bg-slate-900/60 p-4">
          <h3 class="text-lg font-semibold text-cyan-100">Mobile Applications</h3>
          <ul class="mt-2 space-y-2 text-sm text-slate-300">
            <li>Simple mobile app: <strong class="text-white">$5,000 - $15,000</strong></li>
            <li>Moderate app: <strong class="text-white">$15,000 - $50,000</strong></li>
            <li>Complex app: <strong class="text-white">$50,000 - $150,000+</strong></li>
          </ul>
        </div>

        <div class="rounded-xl border border-white/10 bg-slate-900/60 p-4">
          <h3 class="text-lg font-semibold text-cyan-100">Desktop Applications</h3>
          <ul class="mt-2 space-y-2 text-sm text-slate-300">
            <li>Simple desktop app: <strong class="text-white">$5,000 - $15,000</strong></li>
            <li>Medium complexity: <strong class="text-white">$15,000 - $40,000</strong></li>
            <li>Complex desktop app: <strong class="text-white">$40,000 - $100,000+</strong></li>
          </ul>
        </div>
      </div>
    </article>
  </section>

  <GlassCard as="section" class="mt-10" title="What Is Included In Every Engagement">
    <div class="mt-4 grid gap-3 text-slate-300 md:grid-cols-2 lg:grid-cols-4">
      {includedItems.map((item) => <InsetCard><p set:html={item} /></InsetCard>)}
    </div>
  </GlassCard>

  <GlassCard as="section" class="mt-10" title="Where I Stay Deliberately Focused">
    <p class="mt-3 text-slate-300">
      I do not try to offer everything. The business is intentionally centered on websites and bespoke software applications, plus the platforms and integrations needed to support them well.
    </p>
    <div class="mt-4 grid gap-3 md:grid-cols-2">
      <InsetCard class="text-slate-300"><p><strong class="text-white">Primary fit:</strong> Astro, Angular, Ionic, Electron, NestJS, and MySQL for production web and software delivery.</p></InsetCard>
      <InsetCard class="text-slate-300"><p><strong class="text-white">Additional fit:</strong> C# / .NET when a project benefits from Microsoft ecosystem alignment.</p></InsetCard>
    </div>
  </GlassCard>

  <GlassCard as="section" class="mt-10" title="What Influences Final Price?">
    <ul class="mt-4 grid gap-3 text-slate-300 md:grid-cols-3">
      {pricingFactors.map((factor) => <li><InsetCard><p set:html={factor} /></InsetCard></li>)}
    </ul>
    <p class="mt-5 text-slate-300">
      Engagement options include fixed-price projects, hourly development, and long-term monthly retainers. If you have a specific project in mind, we can provide a tailored estimate.
    </p>
  </GlassCard>

  <section class="mt-10 rounded-2xl border border-cyan-300/20 bg-cyan-300/5 p-6 md:p-8">
    <h2 class="text-3xl font-semibold text-white">Ready to scope your project?</h2>
    <p class="mt-3 max-w-3xl text-slate-300">
      Share your goals, timeline, and preferred platform. We can provide a structured estimate and execution plan aligned to your business priorities.
    </p>
    <div class="mt-5 flex flex-wrap gap-3">
      <a href="/contact" class="btn-primary">Request Project Estimate</a>
      <a href="/about" class="btn-secondary">Learn How We Work</a>
    </div>
  </section>

  <GlassCard as="section" class="mt-10" title="Core Technology Stack We Deliver">
    <div class="mt-4 grid gap-3 text-slate-300 md:grid-cols-2">
      {techStack.map((item) => <InsetCard><p set:html={item} /></InsetCard>)}
    </div>
    <p class="mt-5 text-slate-300">
      Astro is a primary offering across landing pages, content hubs, and high-performance website builds.
    </p>
  </GlassCard>
</Layout>
